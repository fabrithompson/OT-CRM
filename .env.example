# ============================================================
#   O'T CRM - Variables de Entorno
#   Copia este archivo: cp .env.example .env
#   Completa los valores antes de levantar la aplicacion.
#   NUNCA commitees el archivo .env real.
# ============================================================


# ------------------------------------------------------------
# BASE DE DATOS (PostgreSQL)
# ------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/otcrm
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=


# ------------------------------------------------------------
# SEGURIDAD
# ------------------------------------------------------------
JWT_SECRET=
BOT_SECRET_KEY=


# ------------------------------------------------------------
# APLICACION
# ------------------------------------------------------------
PORT=8080
APP_DEFAULT_ADMIN_PASSWORD=
APP_BASE_URL=http://localhost:8080
APP_STORAGE_LOCATION=/tmp/uploads
# Origenes CORS permitidos (separados por coma)
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Email remitente para correos transaccionales
APP_EMAIL_FROM=no-reply@tu-dominio.com


# ------------------------------------------------------------
# MICROSERVICIO WHATSAPP (Node.js)
# ------------------------------------------------------------
NODE_BOT_URL=http://localhost:3001
JAVA_BACKEND_URL=http://localhost:8080/api/webhook/whatsapp


# ------------------------------------------------------------
# MICROSERVICIO TELEGRAM (Python)
# ------------------------------------------------------------
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
JAVA_WEBHOOK_URL=http://localhost:8080/api/telegram/webhook
PUBLIC_URL=http://localhost:5000


# ------------------------------------------------------------
# MERCADOPAGO
# ------------------------------------------------------------
MERCADOPAGO_ACCESS_TOKEN=


# ------------------------------------------------------------
# PAYPAL
# ------------------------------------------------------------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox | live
PAYPAL_MODE=sandbox


# ------------------------------------------------------------
# CLOUDINARY
# ------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ------------------------------------------------------------
# RESEND (Emails Transaccionales)
# ------------------------------------------------------------
RESEND_API_KEY=
# true | false
APP_EMAIL_ENABLED=false
