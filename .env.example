# =============================================================================
# OT-CRM — Variables de entorno
# Copiá este archivo a .env y completá los valores reales.
# NUNCA commitees el archivo .env con valores reales.
# =============================================================================

# ── Base de datos (PostgreSQL) ───────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/crm_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=8080
APP_BASE_URL=http://localhost:8080
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET=cambia_esto_por_un_secret_seguro_de_al_menos_64_caracteres
JWT_EXPIRATION_HOURS=10

# ── Bot de WhatsApp ───────────────────────────────────────────────────────────
# Clave compartida entre el backend Java y el bot Node.js
# Generar con: openssl rand -hex 32
BOT_SECRET_KEY=cambia_esto_por_un_secret_seguro
NODE_BOT_URL=http://localhost:3000

# ── Cloudinary (almacenamiento de archivos) ───────────────────────────────────
# Obtener en: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── MercadoPago ───────────────────────────────────────────────────────────────
# Obtener en: https://www.mercadopago.com.ar/developers/panel
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
# Secret para verificar firmas de webhooks (x-signature)
# Obtener en: MercadoPago -> Tus integraciones -> Webhooks -> secret
MERCADOPAGO_WEBHOOK_SECRET=

# ── PayPal ────────────────────────────────────────────────────────────────────
# Obtener en: https://developer.paypal.com/developer/applications
PAYPAL_CLIENT_ID=tu_client_id
PAYPAL_CLIENT_SECRET=tu_client_secret
PAYPAL_MODE=sandbox
# ID del webhook configurado en PayPal -> Webhooks -> tu webhook -> ID
PAYPAL_WEBHOOK_ID=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_...
APP_EMAIL_ENABLED=false
APP_EMAIL_FROM=no-reply@tudominio.com

# ── Telegram ──────────────────────────────────────────────────────────────────
# Obtener en: https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=tu_api_hash

# ── Admin inicial (solo se usa en el primer arranque, si no hay usuarios) ─────
APP_DEFAULT_ADMIN_PASSWORD=cambia_esto_inmediatamente
APP_DEFAULT_ADMIN_EMAIL=admin@tudominio.com

# ── Spring profiles ───────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
